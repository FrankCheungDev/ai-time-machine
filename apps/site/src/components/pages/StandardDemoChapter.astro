---
import BaseLayout from "../layout/BaseLayout.astro";
import {
  commonLabels,
  demoChapterCopy,
  type DemoChapterId,
} from "../../i18n/pages";
import type { Locale } from "../../i18n/locales";
import { getLocalizedLearningChapter } from "../../i18n/learning";
import ChapterJourney from "../learning/ChapterJourney.svelte";
import ChapterProgress from "../learning/ChapterProgress.astro";

interface Props {
  locale: Locale;
  chapterId: DemoChapterId;
}

const { locale, chapterId } = Astro.props;

if (!Astro.slots.has("demo")) {
  throw new Error(
    `StandardDemoChapter requires the named "demo" slot for chapter "${chapterId}".`,
  );
}

const copy = demoChapterCopy[chapterId][locale];
const common = commonLabels[locale];
const chapter = getLocalizedLearningChapter(chapterId, locale);
---

<BaseLayout title={copy.title} description={copy.description} locale={locale}>
  <main class="chapter-main">
    <ChapterProgress {locale} {chapterId} />
    <p class="eyebrow">{chapter.label}</p>
    <h1 class="page-title">{copy.title}</h1>
    <p class="lede">{copy.lede}</p>
    <slot name="demo" />

    <section class="section-band" aria-labelledby={copy.notesId}>
      <p class="eyebrow">{copy.notesEyebrow}</p>
      <h2 id={copy.notesId}>{copy.notesTitle}</h2>
      <p>{copy.notesBody}</p>
      <p class="eyebrow">{common.references}</p>
      <ul>
        {
          copy.references.map((reference) => (
            <li>
              <a href={reference.href}>{reference.label}</a>
            </li>
          ))
        }
      </ul>
    </section>
    <ChapterJourney client:load {locale} {chapterId} />
  </main>
</BaseLayout>
