---
import "../../styles/tokens.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "交互式人工智能图解史：用图解、动画和轻量交互解释 AI 技术演化。"
} = Astro.props;

const pathname = Astro.url.pathname;
const isCurrentPage = (href: string) => pathname === href;
const isChapterSection = pathname.startsWith("/chapters/");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | 交互式人工智能图解史</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">AI</span>
        <span>交互式人工智能图解史</span>
      </a>
      <nav aria-label="主导航">
        <a
          href="/"
          aria-current={isCurrentPage("/") ? "page" : undefined}
        >
          总览
        </a>
        <a
          href="/timeline/"
          aria-current={isCurrentPage("/timeline/") ? "page" : undefined}
        >
          时间线
        </a>
        <a
          href="/lineage/"
          aria-current={isCurrentPage("/lineage/") ? "page" : undefined}
        >
          谱系图
        </a>
        <a
          href="/#mvp"
          class:list={[{ "is-active-section": isChapterSection }]}
          aria-current={isChapterSection ? "page" : undefined}
        >
          章节主线
        </a>
        <a
          href="/diagrams/"
          aria-current={isCurrentPage("/diagrams/") ? "page" : undefined}
        >
          图源
        </a>
      </nav>
    </header>
    <slot />
  </body>
</html>
