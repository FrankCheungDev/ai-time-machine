---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { aiLineageEdges, aiLineageNodes } from "@ai-history/data";

const nodeById = Object.fromEntries(aiLineageNodes.map((node) => [node.id, node]));
const lineageNodeWidth = 132;
const lineageNodeHeight = 72;
const lineageNodeRadius = 8;
type LineageNode = (typeof aiLineageNodes)[number];

function getLineageEdgeGeometry(from: LineageNode, to: LineageNode) {
  const fromCenterX = from.x + lineageNodeWidth / 2;
  const fromCenterY = from.y + lineageNodeHeight / 2;
  const toCenterX = to.x + lineageNodeWidth / 2;
  const toCenterY = to.y + lineageNodeHeight / 2;
  const dx = toCenterX - fromCenterX;
  const dy = toCenterY - fromCenterY;
  const isHorizontal = Math.abs(dx) >= Math.abs(dy);

  if (isHorizontal) {
    const x1 = dx >= 0 ? from.x + lineageNodeWidth : from.x;
    const x2 = dx >= 0 ? to.x : to.x + lineageNodeWidth;
    const y1 = fromCenterY;
    const y2 = toCenterY;

    return {
      x1,
      y1,
      x2,
      y2,
      labelX: (x1 + x2) / 2,
      labelY: (y1 + y2) / 2 - 10,
    };
  }

  const x1 = fromCenterX;
  const x2 = toCenterX;
  const y1 = dy >= 0 ? from.y + lineageNodeHeight : from.y;
  const y2 = dy >= 0 ? to.y : to.y + lineageNodeHeight;

  return {
    x1,
    y1,
    x2,
    y2,
    labelX: (x1 + x2) / 2 + 18,
    labelY: (y1 + y2) / 2,
  };
}
---

<BaseLayout title="AI 技术谱系图" description="按范式理解符号主义、统计学习、神经网络、基础模型、RAG 与 Agent 的关系。">
  <main class="chapter-main">
    <p class="eyebrow">Paradigm Map</p>
    <h1 class="page-title">AI 技术谱系图</h1>
    <p class="lede">
      同一项技术往往不是突然出现，而是在旧问题和新约束之间迁移。谱系图帮助你看到范式之间的继承关系。
    </p>

    <div class="lineage-view-controls" aria-label="谱系图显示模式" data-lineage-view-controls>
      <button type="button" data-lineage-view="fit" aria-pressed="true">适配屏幕</button>
      <button type="button" data-lineage-view="detail" aria-pressed="false">放大查看</button>
    </div>

    <section
      class="lineage-panel"
      aria-label="AI 技术谱系 SVG 图，可适配屏幕或横向滚动查看完整图解"
      tabindex="0"
      data-lineage-panel
      data-view="fit"
      data-mobile-scroll-scene
    >
      <svg viewBox="0 0 1120 480" role="img" aria-labelledby="lineage-title">
        <title id="lineage-title">AI 技术谱系图</title>
        <defs>
          <marker id="lineage-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z"></path>
          </marker>
        </defs>

        {aiLineageEdges.map((edge) => {
          const from = nodeById[edge.from];
          const to = nodeById[edge.to];
          const geometry = getLineageEdgeGeometry(from, to);
          return (
            <>
              <line
                id={`arrow-${edge.id}`}
                x1={geometry.x1}
                y1={geometry.y1}
                x2={geometry.x2}
                y2={geometry.y2}
                marker-end="url(#lineage-arrow)"
              />
              <text class="edge-label" x={geometry.labelX} y={geometry.labelY} text-anchor="middle">{edge.label}</text>
            </>
          );
        })}

        {aiLineageNodes.map((node) => (
          <a href={node.href ?? "#"} aria-label={`${node.label}：${node.description}`}>
            <g id={`node-${node.id}`} class={`lineage-node ${node.group}`}>
              <rect x={node.x} y={node.y} width={lineageNodeWidth} height={lineageNodeHeight} rx={lineageNodeRadius}></rect>
              <text x={node.x + lineageNodeWidth / 2} y={node.y + 32} text-anchor="middle">{node.label}</text>
              <text class="node-caption" x={node.x + lineageNodeWidth / 2} y={node.y + 52} text-anchor="middle">{node.group}</text>
            </g>
          </a>
        ))}
      </svg>
    </section>

    <section class="section-band" aria-labelledby="lineage-notes">
      <p class="eyebrow">阅读方式</p>
      <h2 id="lineage-notes">先看范式，再看 demo</h2>
      <p>
        从左到右看，你会看到 AI 从规则与搜索走向统计学习，再走向神经网络与基础模型。
        RAG 和 Agent 不是孤立应用，而是现代模型连接知识、工具和任务循环的系统化结果。
      </p>
    </section>
  </main>
</BaseLayout>

<script>
  const lineagePanel = document.querySelector("[data-lineage-panel]");
  const lineageButtons = document.querySelectorAll("[data-lineage-view]");

  function setLineageView(view: string) {
    if (!(lineagePanel instanceof HTMLElement)) {
      return;
    }

    lineagePanel.dataset.view = view;

    lineageButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      button.setAttribute(
        "aria-pressed",
        String(button.dataset.lineageView === view),
      );
    });
  }

  lineageButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement) || !button.dataset.lineageView) {
        return;
      }

      setLineageView(button.dataset.lineageView);
    });
  });
</script>
